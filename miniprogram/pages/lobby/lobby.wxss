.container { padding: 30rpx; min-height: 100vh; background: var(--color-bg); }

.header { text-align: center; margin: 40rpx 0; }
.title { font-size: 40rpx; font-weight: bold; }

/* Room code */
.room-code-section { text-align: center; margin: 40rpx 0; }
.label { font-size: 26rpx; color: var(--color-text-dim); display: block; margin-bottom: 12rpx; }
.room-code-box { padding: 24rpx; background: var(--color-surface); border-radius: 16rpx; margin: 16rpx 0; }
.room-code { font-size: 64rpx; font-weight: bold; letter-spacing: 16rpx; color: var(--color-primary); }
.copy-btn { margin-top: 16rpx; font-size: 24rpx; background: transparent; color: var(--color-accent); }

/* Player list */
.player-list { margin: 40rpx 0; }
.section-title { font-size: 26rpx; color: var(--color-text-dim); margin-bottom: 12rpx; }
.player-item {
  display: flex; justify-content: space-between; align-items: center;
  padding: 20rpx; background: var(--color-surface); border-radius: 8rpx;
  margin-bottom: 8rpx;
}
.player-name { font-size: 28rpx; }
.player-status { font-size: 22rpx; }
.player-status.online { color: var(--color-success); }
.player-status.offline { color: var(--color-text-dim); }

.waiting-hint { text-align: center; color: var(--color-text-dim); padding: 40rpx; }

.start-btn {
  width: 100%; margin-top: 40rpx; padding: 24rpx;
  font-size: 32rpx; font-weight: bold; border-radius: 16rpx;
}
.start-btn[disabled] { opacity: 0.4; }

/* Join */
.input-group { margin-bottom: 24rpx; }
.room-input, .name-input {
  width: 100%; padding: 20rpx; font-size: 32rpx;
  background: var(--color-surface); border-radius: 12rpx; color: #fff;
}
.join-btn { width: 100%; margin-top: 40rpx; padding: 24rpx; font-size: 32rpx; }

<view class="container">
  <view class="header">
    <text class="title">桌游助手</text>
    <text class="subtitle">AI 语音电子裁判</text>
  </view>

  <!-- 游戏列表 -->
  <view class="game-list" wx:if="{{!loading}}">
    <view
      class="game-card"
      wx:for="{{gameTypes}}"
      wx:key="game_id"
      data-game-id="{{item.game_id}}"
      data-min-players="{{item.min_players}}"
      data-max-players="{{item.max_players}}"
      bindtap="onGameSelect"
    >
      <text class="game-icon">{{item.icon || '🎲'}}</text>
      <view class="game-info">
        <text class="game-name">{{item.name}}</text>
        <text class="game-detail">{{item.min_players}}-{{item.max_players}}人</text>
      </view>
      <text class="arrow">›</text>
    </view>
  </view>

  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <!-- 加入房间 -->
  <view class="join-section">
    <view class="divider"><text>或</text></view>

    <view class="join-input-row" wx:if="{{showJoinInput}}">
      <input
        class="code-input"
        placeholder="输入房间号"
        value="{{joinRoomCode}}"
        bindinput="onInputRoomCode"
        maxlength="4"
      />
      <button class="join-btn" bindtap="onJoinByCode">加入</button>
    </view>

    <button class="toggle-join" bindtap="onShowJoinInput">
      {{showJoinInput ? '取消' : '通过房间号加入'}}
    </button>
  </view>
</view>

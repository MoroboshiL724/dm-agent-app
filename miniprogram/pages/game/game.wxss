.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  padding: 12rpx;
  background: var(--color-bg);
}

.connection-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.7);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 100;
}
.connection-text { font-size: 36rpx; color: var(--color-warning); }
.connection-detail { font-size: 24rpx; color: var(--color-text-dim); margin-top: 8rpx; }

/* Phase bar */
.phase-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 16rpx;
  background: var(--color-surface);
  border-radius: 12rpx;
  margin-bottom: 8rpx;
}
.phase-icon { font-size: 40rpx; }
.phase-name { font-size: 32rpx; font-weight: bold; color: var(--color-primary); }
.round-info { font-size: 22rpx; color: var(--color-text-dim); }

/* Announcements */
.announcement-area {
  flex: 1;
  background: var(--color-surface);
  border-radius: 12rpx;
  padding: 16rpx;
  margin-bottom: 8rpx;
  max-height: 40vh;
}
.announcement-item {
  padding: 12rpx 0;
  border-bottom: 1rpx solid rgba(255,255,255,0.05);
}
.announcement-text {
  font-size: 26rpx;
  line-height: 1.5;
  color: var(--color-text);
}

/* Player bar */
.player-bar {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  padding: 8rpx;
  margin-bottom: 8rpx;
}
.player-dot {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 8rpx 12rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
}
.player-dot.alive { background: rgba(46,204,113,0.2); color: var(--color-success); }
.player-dot.dead { background: rgba(231,76,60,0.2); color: var(--color-danger); text-decoration: line-through; }
.player-status { font-size: 16rpx; opacity: 0.7; }

/* Role card */
.role-indicator {
  text-align: center;
  padding: 12rpx;
  margin-bottom: 8rpx;
  position: relative;
}
.role-hint { color: var(--color-accent); font-size: 24rpx; }
.role-card {
  margin-top: 8rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #0f3460, #16213e);
  border-radius: 16rpx;
  display: none;
}
.role-card.show { display: block; animation: fadeIn 0.3s; }
.role-name { font-size: 36rpx; font-weight: bold; display: block; }
.role-team { font-size: 24rpx; margin-top: 8rpx; }
.role-team.good { color: var(--color-success); }
.role-team.evil { color: var(--color-danger); }
.role-teammates { font-size: 22rpx; color: var(--color-text-dim); margin-top: 8rpx; }

@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

/* Quick actions */
.quick-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 8rpx;
  justify-content: center;
}
.action-btn {
  padding: 16rpx 28rpx;
  font-size: 24rpx;
  background: var(--color-accent);
  color: #fff;
  border-radius: 24rpx;
}

/* Vote overlay */
.vote-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 50;
}
.vote-panel {
  background: var(--color-surface);
  border-radius: 16rpx;
  padding: 40rpx;
  width: 80vw;
}
.vote-title { font-size: 32rpx; text-align: center; margin-bottom: 24rpx; }
.vote-target {
  width: 100%;
  margin: 12rpx 0;
  padding: 20rpx;
  background: var(--color-accent);
  color: #fff;
  border-radius: 12rpx;
  font-size: 28rpx;
}
.vote-cancel {
  width: 100%;
  margin-top: 16rpx;
  padding: 16rpx;
  background: transparent;
  color: var(--color-text-dim);
  border: 1rpx solid var(--color-text-dim);
  border-radius: 12rpx;
}

/* Input area */
.input-area {
  padding: 12rpx;
  background: var(--color-surface);
  border-radius: 12rpx;
  margin-bottom: 8rpx;
}
.voice-btn {
  width: 100%;
  padding: 28rpx;
  font-size: 30rpx;
  font-weight: bold;
  background: var(--color-accent);
  color: #fff;
  border-radius: 50rpx;
  transition: background 0.15s;
}
.voice-btn.recording {
  background: var(--color-danger);
  animation: pulse 0.5s infinite alternate;
}
@keyframes pulse { from { opacity: 1; } to { opacity: 0.7; } }

.manual-mode { display: flex; gap: 12rpx; }
.manual-input {
  flex: 1;
  padding: 16rpx;
  background: rgba(255,255,255,0.1);
  border-radius: 8rpx;
  color: #fff;
  font-size: 26rpx;
}
.send-btn {
  padding: 16rpx 24rpx;
  background: var(--color-primary);
  color: #fff;
  border-radius: 8rpx;
}
.mode-toggle {
  text-align: center;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: var(--color-text-dim);
}

/* Leave */
.leave-btn {
  text-align: center;
  padding: 12rpx;
  font-size: 22rpx;
  color: var(--color-danger);
  opacity: 0.7;
}
